{
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "sidebysideweb.gr"}],
      "destination": "https://www.sidebysideweb.gr/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    }
  ]
}
