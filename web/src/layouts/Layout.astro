---
import '../styles/global.css'
import CookieConsent from '../components/CookieConsent.astro'
import GtmBody from '../components/GtmBody.astro'
import GtmHead from '../components/GtmHead.astro'
import type {SiteSettings} from '../lib/types'
import {DEFAULT_LOCALE, EN_LOCALE_ENABLED, localeHtmlLang, localizePath, type SiteLocale} from '../lib/i18n'
import {SITE_URL} from '../lib/sanity-config'

interface Props {
  title?: string
  description?: string
  /** When set, used as the full <title> without appending the site name. */
  documentTitle?: string
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  siteSettings: SiteSettings
  locale?: SiteLocale
}

const {title, description, documentTitle, jsonLd, siteSettings, locale = DEFAULT_LOCALE} =
  Astro.props
const pageTitle =
  documentTitle ?? (title ? `${title} | ${siteSettings.siteName}` : siteSettings.siteName)
const pageDescription = description ?? siteSettings.description ?? ''
const canonicalPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`
const elPath = localizePath(canonicalPath, 'el')
const enPath = localizePath(canonicalPath, 'en')
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []
const gtmId = (import.meta.env.PUBLIC_GTM_ID ?? 'GTM-T4W88CDJ').trim()
---

<!doctype html>
<html lang={localeHtmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <CookieConsent />
    {gtmId ? <GtmHead gtmId={gtmId} /> : null}
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="alternate" hreflang="el" href={`${SITE_URL}${elPath}`} />
    {
      EN_LOCALE_ENABLED ? (
        <link rel="alternate" hreflang="en" href={`${SITE_URL}${enPath}`} />
      ) : null
    }
    <link rel="alternate" hreflang="x-default" href={`${SITE_URL}${elPath}`} />
    <!-- Icons only (subset ~6KB); Inter is self-hosted via @fontsource-variable -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0..1,0&display=swap&icon_names=analytics,arrow_forward,build,check_circle,chevron_right,close,design_services,expand_more,format_quote,handshake,history,history_edu,insights,lightbulb,listening,lock,menu,psychology,rocket_launch,schedule,search,support_agent,terminal,trending_up,verified"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0..1,0&display=swap&icon_names=analytics,arrow_forward,build,check_circle,chevron_right,close,design_services,expand_more,format_quote,handshake,history,history_edu,insights,lightbulb,listening,lock,menu,psychology,rocket_launch,schedule,search,support_agent,terminal,trending_up,verified"
      />
    </noscript>
  </head>
  <body class="selection:bg-secondary-container selection:text-on-secondary-fixed">
    {gtmId ? <GtmBody gtmId={gtmId} /> : null}
    <slot />
    <script src="../scripts/micro-animations.ts"></script>
  </body>
</html>
