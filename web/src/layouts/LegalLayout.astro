---
import Layout from './Layout.astro'
import SiteNav from '../components/SiteNav.astro'
import SiteFooter from '../components/SiteFooter.astro'
import type {SiteSettings} from '../lib/types'
import {DEFAULT_LOCALE, type SiteLocale} from '../lib/i18n'
import {getUiStrings} from '../lib/ui-strings'

interface Props {
  title: string
  description?: string
  lastUpdated?: string
  siteSettings: SiteSettings
  locale?: SiteLocale
}

const {title, description, lastUpdated, siteSettings, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
---

<Layout title={title} description={description} siteSettings={siteSettings} locale={locale}>
  <SiteNav siteSettings={siteSettings} locale={locale} />
  <main class="bg-surface-white py-section-mobile md:py-section-desktop">
    <article class="mx-auto max-w-3xl px-margin-container">
      <header class="scroll-reveal mb-10 border-b border-outline-variant pb-8">
        <h1 class="mb-4 text-headline-lg text-primary">{title}</h1>
        {lastUpdated ? (
          <p class="text-sm text-text-muted">{ui.legalLastUpdated} {lastUpdated}</p>
        ) : null}
      </header>
      <div class="legal-prose scroll-reveal stagger-1 space-y-6 text-on-surface-variant">
        <slot />
      </div>
    </article>
  </main>
  <SiteFooter locale={locale} siteSettings={siteSettings} />
</Layout>
