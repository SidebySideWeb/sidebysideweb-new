---
import type {HeroSection} from '../lib/types'
import {resolveHeroImage, resolveHeroImageSrcSet} from '../lib/image'
import {isBookingCta, resolveContactHref} from '../lib/cal-com'
import CalBookingButton from './CalBookingButton.astro'

interface Props {
  hero: HeroSection
}

const {hero} = Astro.props
const heroImageUrl = resolveHeroImage(hero.heroImage, hero.heroImageUrl, 800)
const heroImageSrcSet = resolveHeroImageSrcSet(hero.heroImage, [480, 800, 960])
const heroImageAlt = hero.heroImage?.alt?.trim() || ''
const ctaLink = resolveContactHref(hero.ctaLink ?? '#contact')
const useCalBooking = isBookingCta(hero.ctaLink)
const ctaClass =
  'btn-primary-orange inline-flex h-[56px] w-full items-center justify-center rounded-lg px-8 md:w-auto'
---

<header
  class="hero-gradient flex items-start px-margin-container pb-12 pt-28 md:min-h-screen md:items-center md:pb-0 md:pt-[70px]"
>
  <div class="mx-auto grid w-full max-w-7xl items-center gap-8 md:grid-cols-2 md:gap-gutter">
    <div class="min-w-0 space-y-5 md:space-y-8">
      <h1 class="animate-fade-in-up text-headline-xl text-primary">
        {hero.headline}
      </h1>
      <p class="animate-fade-in-up stagger-1 max-w-xl text-body-lg text-on-surface-variant">
        {hero.subheading}
      </p>
      <div class="animate-fade-in-up stagger-2 space-y-4">
        {
          useCalBooking ? (
            <CalBookingButton class={ctaClass} label={hero.ctaText ?? 'Ζητήστε Ανάλυση Δωρεάν'} />
          ) : (
            <a class={ctaClass} href={ctaLink}>
              {hero.ctaText}
            </a>
          )
        }
        {
          hero.trustSignals?.length ? (
            <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:gap-x-6 sm:gap-y-2">
              {hero.trustSignals.map((signal) => (
                <div class="flex min-w-0 items-center gap-2 text-sm text-on-surface-variant">
                  <span class="material-symbols-outlined shrink-0 text-lg text-accent-teal">
                    {signal.icon ?? 'check_circle'}
                  </span>
                  <span class="break-words">{signal.text}</span>
                </div>
              ))}
            </div>
          ) : null
        }
      </div>
    </div>
    {
      heroImageUrl ? (
        <div class="animate-fade-in-up stagger-2 relative min-w-0 w-full">
          <img
            alt={heroImageAlt}
            class="h-auto w-full max-w-full rounded-2xl object-cover shadow-2xl"
            src={heroImageUrl}
            srcset={heroImageSrcSet}
            sizes="(max-width: 768px) 100vw, min(50vw, 800px)"
            width="800"
            height="503"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      ) : null
    }
  </div>
</header>
