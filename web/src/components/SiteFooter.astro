---
import type {SiteSettings} from '../lib/types'
import {DEFAULT_LOCALE, localizePath, type SiteLocale} from '../lib/i18n'
import {getRecaptchaSiteKey} from '../lib/recaptcha'
import {getFooterCopy, getUiStrings} from '../lib/ui-strings'
import CalBookingButton from './CalBookingButton.astro'
import ContactFormModal from './contact/ContactFormModal'

interface Props {
  siteSettings: SiteSettings
  locale?: SiteLocale
}

const {siteSettings, locale = DEFAULT_LOCALE} = Astro.props
const footer = getFooterCopy(locale)
const ui = getUiStrings(locale)
const year = new Date().getFullYear()
const privacyHref = localizePath('/privacy-policy', locale)
const recaptchaSiteKey = getRecaptchaSiteKey()

const socialLinks = [
  {label: 'LinkedIn', href: 'https://www.linkedin.com/in/dimitriosgeronikolos/'},
  {label: 'TikTok', href: 'https://www.tiktok.com/@sidebysideweb'},
] as const

const contactFormCopy = {
  openButton: ui.contactFormOpen,
  modalTitle: ui.contactFormTitle,
  firstName: ui.contactFormFirstName,
  lastName: ui.contactFormLastName,
  companyName: ui.contactFormCompany,
  email: ui.contactFormEmail,
  phone: ui.contactFormPhone,
  message: ui.contactFormMessage,
  consentPrefix: ui.contactFormConsentPrefix,
  consentLink: ui.contactFormConsentLink,
  consentSuffix: ui.contactFormConsentSuffix,
  submit: ui.contactFormSubmit,
  submitting: ui.contactFormSubmitting,
  success: ui.contactFormSuccess,
  close: ui.contactFormClose,
  requiredError: ui.contactFormRequiredError,
  consentError: ui.contactFormConsentError,
  recaptchaError: ui.contactFormRecaptchaError,
  genericError: ui.contactFormGenericError,
}
---

<footer class="relative w-full overflow-hidden bg-primary text-white" id="contact">
  <div class="pointer-events-none absolute inset-0 opacity-10">
    <div
      class="absolute top-0 right-0 h-96 w-96 translate-x-1/2 -translate-y-1/2 rounded-full bg-secondary-container blur-[100px]"
    />
  </div>

  <div
    class="relative z-10 mx-auto max-w-7xl px-margin-container py-section-mobile md:py-section-desktop"
  >
    <div class="scroll-reveal mx-auto max-w-4xl text-center text-on-primary">
      <h2 class="mb-6 text-headline-lg">{ui.contactCtaTitle}</h2>
      <p class="mb-12 text-body-lg text-on-primary-container">{ui.contactCtaBody}</p>
    </div>
    <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center gap-8 text-center text-on-primary">
      <div class="flex w-full flex-col items-center justify-center gap-gutter md:flex-row">
        <CalBookingButton
          class="btn-primary-orange h-[60px] rounded-lg px-10 shadow-xl"
          label={ui.contactCtaButton}
        />
        <ContactFormModal
          client:load
          copy={contactFormCopy}
          privacyHref={privacyHref}
          recaptchaSiteKey={recaptchaSiteKey}
        />
      </div>
      <div
        class="flex w-full flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap sm:gap-x-8 sm:gap-y-3"
      >
        <a
          class="border-b border-on-primary-container pb-1 text-body-md text-on-primary transition-colors hover:text-secondary"
          href={`mailto:${siteSettings.contactEmail}`}
        >
          {siteSettings.contactEmail}
        </a>
        {
          siteSettings.contactPhone ? (
            <a
              class="border-b border-on-primary-container pb-1 text-body-md text-on-primary transition-colors hover:text-secondary"
              href={`tel:${siteSettings.contactPhone.replace(/\s/g, '')}`}
            >
              {siteSettings.contactPhone}
            </a>
          ) : null
        }
        {
          socialLinks.map((link) => (
            <a
              class="text-sm font-semibold uppercase tracking-wider text-white/80 transition-colors hover:text-secondary"
              href={link.href}
              rel="noopener noreferrer"
              target="_blank"
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 opacity-70">
        <div class="flex items-center gap-2 text-sm">
          <span class="material-symbols-outlined text-sm">lock</span>
          {ui.contactCtaConfidentiality}
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span class="material-symbols-outlined text-sm">schedule</span>
          {ui.contactCtaResponse}
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span class="material-symbols-outlined text-sm">verified</span>
          {ui.contactCtaExpertise}
        </div>
      </div>
    </div>
  </div>

  <div
    class="relative z-10 mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 border-t border-white/10 px-margin-container py-8 md:flex-row"
  >
    <p class="text-xs text-white/60">
      © {year} {siteSettings.siteName}. {footer.rights}
    </p>
    <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-white/60">
      {
        footer.legalLinks.map((link) => (
          <a class="hover:text-secondary" href={link.href}>
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
