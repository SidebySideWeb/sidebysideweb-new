---
interface Props {
  headline: string
  author: string
  role: string
}

const {headline, author, role} = Astro.props
---

<section class="relative overflow-hidden bg-primary py-section-mobile text-on-primary md:py-section-desktop">
  <div class="relative z-10 mx-auto max-w-3xl px-margin-container text-center">
    <div class="scroll-reveal">
      <h2 class="mb-8 text-headline-md">Η Άποψη του Πελάτη</h2>
      <span
        class="material-symbols-outlined mb-8 text-7xl text-secondary"
        style="font-variation-settings: 'FILL' 1;"
      >
        format_quote
      </span>
      <p class="mb-10 text-2xl italic leading-relaxed md:text-3xl">«{headline}»</p>
      <div>
        <p class="text-xl font-semibold">{author}</p>
        <p class="text-label-md uppercase tracking-widest text-on-primary-container">{role}</p>
      </div>
    </div>
  </div>
</section>
