---
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'
import CaseStudyCard from '../CaseStudyCard.astro'

interface Props {
  caseStudies: CaseStudy[]
  currentSlug?: string
  locale?: SiteLocale
}

const {caseStudies, currentSlug, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const related = caseStudies.filter((study) => study.slug?.current !== currentSlug).slice(0, 3)
---

{
  related.length ? (
    <section class="bg-surface-white py-section-mobile md:py-section-desktop">
      <div class="mx-auto max-w-7xl px-margin-container">
        <h2 class="scroll-reveal mb-12 text-headline-md text-primary">{ui.relatedCaseStudiesTitle}</h2>
        <div class="grid gap-gutter md:grid-cols-3">
          {related.map((study, index) => (
            <CaseStudyCard caseStudy={study} locale={locale} staggerClass={`stagger-${index + 1}`} />
          ))}
        </div>
      </div>
    </section>
  ) : null
}
