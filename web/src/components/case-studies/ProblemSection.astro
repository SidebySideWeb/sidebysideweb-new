---
import {getProblemBullets} from '../../lib/case-study-helpers'
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'

interface Props {
  caseStudy: CaseStudy
  locale?: SiteLocale
}

const {caseStudy, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const bullets = getProblemBullets(caseStudy)
---

<section class="bg-surface-white py-section-mobile md:py-section-desktop">
  <div class="mx-auto max-w-7xl px-margin-container">
    <div class="grid items-start gap-20 lg:grid-cols-2">
      <div class="scroll-reveal step-content-from-left">
        <h2 class="mb-2 text-headline-lg text-primary">{ui.problemTitle}</h2>
        {caseStudy.problem?.title ? (
          <h3 class="mb-6 text-2xl font-semibold text-secondary">{caseStudy.problem.title}</h3>
        ) : null}
        {caseStudy.problem?.description ? (
          <p class="mb-8 leading-relaxed text-on-surface-variant">{caseStudy.problem.description}</p>
        ) : null}
        {
          bullets.length ? (
            <ul class="space-y-4">
              {bullets.map((bullet) => (
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined shrink-0 font-bold text-error">close</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          ) : caseStudy.problem?.impact ? (
            <p class="text-on-surface-variant">{caseStudy.problem.impact}</p>
          ) : null
        }
      </div>
      <div class="scroll-reveal step-content-from-right stagger-2">
        <div class="overflow-hidden rounded-2xl border border-outline-variant/30 bg-surface-container-low p-8 shadow-xl">
          <div class="flex h-64 items-end gap-2">
            <div class="h-[60%] w-full rounded-t-lg bg-primary/20 transition-colors hover:bg-primary/30" />
            <div class="h-[80%] w-full rounded-t-lg bg-primary/40 transition-colors hover:bg-primary/50" />
            <div class="h-[40%] w-full rounded-t-lg bg-primary/10 transition-colors hover:bg-primary/20" />
            <div class="h-full w-full rounded-t-lg bg-secondary transition-colors hover:bg-secondary/80" />
            <div class="h-[55%] w-full rounded-t-lg bg-primary/30 transition-colors hover:bg-primary/40" />
          </div>
          <p class="mt-6 text-center text-label-md font-bold uppercase tracking-widest text-primary">
            {caseStudy.problem?.visualizationLabel ?? ui.problemDefaultLabel}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
