---
import {getRoiLabel} from '../../lib/case-study-helpers'
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'

interface Props {
  caseStudy: CaseStudy
  locale?: SiteLocale
}

const {caseStudy, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const roi = getRoiLabel(caseStudy) ?? '—'
---

<section class="bg-surface-bright py-section-mobile md:py-section-desktop">
  <div class="mx-auto max-w-7xl px-margin-container">
    <div class="scroll-reveal mb-16 text-center">
      <h2 class="mb-4 text-headline-lg text-primary">{ui.investmentTitle}</h2>
      <p class="mx-auto max-w-xl text-on-surface-variant">
        {ui.investmentSubtitle}
      </p>
    </div>
    <div class="grid gap-gutter md:grid-cols-3">
      <div class="scroll-reveal stagger-1 flex flex-col items-center rounded-2xl border border-outline-variant/30 bg-white p-10">
        <p class="mb-4 text-label-md uppercase text-on-surface-variant">{ui.investmentCost}</p>
        <p class="text-headline-xl font-bold text-primary">{caseStudy.investment?.amount ?? '—'}</p>
        {caseStudy.investment?.breakdown ? (
          <p class="mt-4 text-center text-sm text-on-surface-variant">{caseStudy.investment.breakdown}</p>
        ) : null}
      </div>
      <div class="scroll-reveal stagger-2 relative flex scale-105 flex-col items-center rounded-2xl border-2 border-secondary bg-white p-10 shadow-xl">
        <div class="absolute -top-4 rounded-full bg-secondary px-4 py-1 text-label-md text-on-primary">
          Timeline
        </div>
        <p class="mb-4 text-label-md uppercase text-on-surface-variant">{ui.investmentTimeline}</p>
        <p class="text-headline-xl font-bold text-secondary">{caseStudy.investment?.timeline ?? '—'}</p>
      </div>
      <div class="scroll-reveal stagger-3 flex flex-col items-center rounded-2xl border border-outline-variant/30 bg-white p-10">
        <p class="mb-4 text-label-md uppercase text-on-surface-variant">ROI</p>
        <p class="text-headline-xl font-bold text-primary">{roi}</p>
        <p class="mt-4 text-center text-sm text-on-surface-variant">{ui.investmentPayback}</p>
      </div>
    </div>
  </div>
</section>
