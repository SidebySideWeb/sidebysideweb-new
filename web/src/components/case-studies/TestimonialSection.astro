---
import type {CaseStudy} from '../../lib/types'

interface Props {
  caseStudy: CaseStudy
}

const {caseStudy} = Astro.props
const testimonial = caseStudy.testimonial
---

{
  testimonial?.quote ? (
    <section class="relative overflow-hidden bg-primary py-section-mobile text-on-primary md:py-section-desktop">
      <div class="relative z-10 mx-auto max-w-3xl px-margin-container text-center">
        <div class="scroll-reveal">
          <span
            class="material-symbols-outlined mb-8 text-7xl text-secondary"
            style="font-variation-settings: 'FILL' 1;"
          >
            format_quote
          </span>
          <p class="mb-10 text-2xl italic leading-relaxed md:text-3xl">"{testimonial.quote}"</p>
          <div>
            <p class="text-xl font-semibold">{testimonial.author}</p>
            <p class="text-label-md uppercase tracking-widest text-on-primary-container">
              {[testimonial.role, testimonial.company].filter(Boolean).join(', ')}
            </p>
          </div>
        </div>
      </div>
    </section>
  ) : null
}
