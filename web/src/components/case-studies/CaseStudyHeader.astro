---
import {getCaseStudyCategoryLabel, getMainResult} from '../../lib/case-study-helpers'
import {DEFAULT_LOCALE, localizePath, type SiteLocale} from '../../lib/i18n'
import {resolveCaseStudyImage} from '../../lib/image'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'

interface Props {
  caseStudy: CaseStudy
  locale?: SiteLocale
}

const {caseStudy, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const homePath = localizePath('/', locale)
const casesPath = `${homePath}#cases`
const category = getCaseStudyCategoryLabel(caseStudy, locale)
const mainResult = getMainResult(caseStudy)
const imageUrl = resolveCaseStudyImage(caseStudy, 1280)
---

<header class="relative overflow-hidden bg-gradient-to-br from-primary to-primary-container pt-32 pb-section-mobile text-on-primary md:pb-section-desktop">
  <div class="relative z-10 mx-auto max-w-7xl px-margin-container">
    <nav class="scroll-reveal mb-6 flex flex-wrap gap-2 text-sm" aria-label="Breadcrumb">
      <a class="text-on-primary-container transition-colors hover:text-on-primary" href={homePath}>{ui.caseStudyBreadcrumbHome}</a>
      <span class="text-on-primary-container">/</span>
      <a class="text-on-primary-container transition-colors hover:text-on-primary" href={casesPath}>
        {ui.caseStudyBreadcrumbCases}
      </a>
      <span class="text-on-primary-container">/</span>
      <span class="text-on-primary">{caseStudy.title}</span>
    </nav>

    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="scroll-reveal stagger-1">
        <span class="mb-6 inline-block rounded-full bg-secondary px-4 py-1 text-label-md uppercase tracking-wider text-on-primary">
          {category}
        </span>
        <h1 class="mb-6 text-headline-xl leading-tight">{caseStudy.title}</h1>
        <p class="mb-10 max-w-xl text-body-lg text-on-primary-container">
          {caseStudy.summary ?? caseStudy.problem?.description}
        </p>
        <div class="grid grid-cols-3 gap-6 border-t border-on-primary-container/20 pt-8">
          <div>
            <p class="mb-1 text-xs uppercase text-on-primary-container">{ui.headerInvestment}</p>
            <p class="text-2xl font-bold">{caseStudy.investment?.amount ?? '—'}</p>
          </div>
          <div>
            <p class="mb-1 text-xs uppercase text-on-primary-container">{ui.headerDuration}</p>
            <p class="text-2xl font-bold">{caseStudy.investment?.timeline ?? '—'}</p>
          </div>
          <div>
            <p class="mb-1 text-xs uppercase text-on-primary-container">{ui.headerResult}</p>
            <p class="text-2xl font-bold">{mainResult ?? '—'}</p>
          </div>
        </div>
      </div>
      <div class="scroll-reveal stagger-2 h-[400px] overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10">
        <div
          class="h-full w-full bg-cover bg-center transition-transform duration-700 hover:scale-105"
          style={`background-image: url('${imageUrl}')`}
          role="img"
          aria-label={caseStudy.featuredImage?.alt ?? caseStudy.title}
        />
      </div>
    </div>
  </div>
</header>
