---
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import {getUiStrings} from '../../lib/ui-strings'
import CalBookingButton from '../CalBookingButton.astro'

interface Props {
  locale?: SiteLocale
}

const {locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
---

<section class="bg-primary py-section-mobile text-center text-on-primary md:py-section-desktop">
  <div class="scroll-reveal mx-auto max-w-3xl px-margin-container">
    <h2 class="mb-6 text-headline-lg">{ui.caseStudyCtaTitle}</h2>
    <p class="mb-10 text-body-lg text-on-primary-container">
      {ui.caseStudyCtaBody}
    </p>
    <CalBookingButton
      class="btn-primary-orange inline-flex rounded-xl px-10 py-4 shadow-lg transition-all hover:scale-105 hover:shadow-secondary/20"
      label={ui.caseStudyCtaButton}
    />
  </div>
</section>
