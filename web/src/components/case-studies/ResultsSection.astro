---
import {parseStat} from '../../lib/parse-stat'
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'

interface Props {
  caseStudy: CaseStudy
  locale?: SiteLocale
}

const {caseStudy, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const metrics = caseStudy.results?.metrics ?? []

function shouldAnimateCounter(value: string | undefined): boolean {
  const parsed = parseStat(value)
  if (parsed.target === null) return false
  if (parsed.suffix === '%') return true
  return !parsed.prefix && !parsed.suffix
}
---

<section class="bg-surface-white py-section-mobile md:py-section-desktop">
  <div class="mx-auto max-w-7xl px-margin-container">
    <div class="scroll-reveal mb-12 text-center">
      <h2 class="mb-4 text-headline-lg text-primary">{ui.resultsTitle}</h2>
      {caseStudy.results?.summary ? (
        <p class="mx-auto max-w-2xl text-body-md text-on-surface-variant">{caseStudy.results.summary}</p>
      ) : null}
    </div>
    <div class="grid grid-cols-1 gap-gutter sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map((metric, index) => {
          const parsed = parseStat(metric.value)
          const animate = shouldAnimateCounter(metric.value)

          return (
            <div
              class={`scroll-reveal stagger-${index + 1} min-w-0 rounded-2xl border border-outline-variant/20 bg-surface shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl`}
            >
              <div class="flex min-h-[148px] flex-col items-center justify-center px-4 py-8 text-center sm:px-6">
                <p class="mb-3 w-full text-2xl leading-tight font-bold break-words text-primary sm:text-3xl lg:text-[2rem]">
                  {animate ? (
                    <span
                      class="counter tabular-nums"
                      data-target={parsed.target}
                      data-prefix={parsed.prefix}
                      data-suffix={parsed.suffix}
                      data-fallback={parsed.display}
                      data-duration="1500"
                    >
                      {parsed.prefix}0{parsed.suffix}
                    </span>
                  ) : (
                    metric.value
                  )}
                </p>
                {metric.label ? (
                  <p class="w-full text-[11px] font-semibold uppercase tracking-widest text-on-surface-variant sm:text-label-md">
                    {metric.label}
                  </p>
                ) : null}
                {metric.comparison ? (
                  <p class="mt-2 w-full text-sm leading-snug text-text-muted">{metric.comparison}</p>
                ) : null}
              </div>
            </div>
          )
        })
      }
    </div>
  </div>
</section>
