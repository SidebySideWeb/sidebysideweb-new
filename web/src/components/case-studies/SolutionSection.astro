---
import {blocksToPlainText} from '../../lib/cms'
import {getSolutionPhases} from '../../lib/case-study-helpers'
import {DEFAULT_LOCALE, type SiteLocale} from '../../lib/i18n'
import type {CaseStudy} from '../../lib/types'
import {getUiStrings} from '../../lib/ui-strings'

interface Props {
  caseStudy: CaseStudy
  locale?: SiteLocale
}

const {caseStudy, locale = DEFAULT_LOCALE} = Astro.props
const ui = getUiStrings(locale)
const technologies = caseStudy.solution?.technologies ?? []
const phases = getSolutionPhases(caseStudy)
const description = blocksToPlainText(caseStudy.solution?.description as unknown[])

const techIcons: Record<string, string> = {
  'make.com': 'hub',
  twitter: 'api',
  postgresql: 'database',
  node: 'terminal',
  woocommerce: 'shopping_cart',
  default: 'settings',
}

function iconForTech(tech: string): string {
  const key = Object.keys(techIcons).find((part) => tech.toLowerCase().includes(part))
  return techIcons[key ?? 'default']
}
---

<section class="border-y border-outline-variant/10 bg-surface-bright py-section-mobile md:py-section-desktop">
  <div class="mx-auto max-w-3xl px-margin-container text-center">
    <h2 class="scroll-reveal mb-6 text-headline-lg text-primary">{ui.solutionTitle}</h2>
    {caseStudy.solution?.title ? (
      <h3 class="scroll-reveal stagger-1 mb-4 text-xl font-semibold text-secondary">
        {caseStudy.solution.title}
      </h3>
    ) : null}
    {description ? (
      <p class="scroll-reveal stagger-2 mb-12 text-body-lg text-on-surface-variant">{description}</p>
    ) : null}

    {
      technologies.length ? (
        <div class="mb-16 grid gap-8 md:grid-cols-3">
          {technologies.slice(0, 3).map((tech, index) => (
            <div
              class={`scroll-reveal stagger-${index + 1} group rounded-xl border border-outline-variant/20 bg-white p-6 shadow-sm transition-all hover:border-primary`}
            >
              <span class="material-symbols-outlined mb-4 text-4xl text-secondary">
                {iconForTech(tech)}
              </span>
              <h4 class="mb-2 text-lg font-semibold">{tech.split(':')[0]?.trim() ?? tech}</h4>
              <p class="text-sm text-on-surface-variant">{tech}</p>
            </div>
          ))}
        </div>
      ) : null
    }

    <div class="space-y-6 text-left">
      {
        phases.length
          ? phases.map((phase, index) => (
              <div class={`scroll-reveal stagger-${index + 1} flex items-start gap-6`}>
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary font-bold text-on-primary">
                  {index + 1}
                </div>
                <div>
                  <h5 class="mb-1 text-xl font-semibold text-primary">{phase.title}</h5>
                  {phase.description ? (
                    <p class="text-on-surface-variant">{phase.description}</p>
                  ) : null}
                </div>
              </div>
            ))
          : technologies.slice(0, 3).map((tech, index) => (
              <div class={`scroll-reveal stagger-${index + 1} flex items-start gap-6`}>
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary font-bold text-on-primary">
                  {index + 1}
                </div>
                <div>
                  <h5 class="mb-1 text-xl font-semibold text-primary">{tech}</h5>
                  <p class="text-on-surface-variant">{ui.solutionFallback}</p>
                </div>
              </div>
            ))
      }
    </div>
  </div>
</section>
