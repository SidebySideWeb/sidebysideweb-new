---
import StatCounter from './ui/StatCounter.astro'
import type {CredentialsSection} from '../lib/types'

interface Props {
  credentials: CredentialsSection
}

const {credentials} = Astro.props
---

<section class="bg-primary py-12 text-on-primary">
  <div class="mx-auto max-w-7xl px-margin-container">
    <h2 class="scroll-reveal mb-12 text-center text-headline-md">
      {credentials.headline}
    </h2>
    <div class="grid grid-cols-1 gap-gutter text-center md:grid-cols-3">
      {
        credentials.credentials?.map((item, index) => (
          <div class={`scroll-reveal stagger-${index + 1}`}>
            <p class="mb-2 text-headline-xl font-bold text-secondary">
              <StatCounter value={item.stat ?? ''} class="text-headline-xl font-bold text-secondary" />
            </p>
            {item.label ? (
              <p class="text-xs font-bold uppercase tracking-widest text-on-primary-container">
                {item.label}
              </p>
            ) : null}
            <p class="mt-4 px-4 text-sm opacity-80">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
