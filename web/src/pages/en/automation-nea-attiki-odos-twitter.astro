---
import Layout from '../../layouts/Layout.astro'
import SiteNav from '../../components/SiteNav.astro'
import SiteFooter from '../../components/SiteFooter.astro'
import AttikiCaseStudyView from '../../components/case-studies/AttikiCaseStudyView.astro'
import {getHomePageData} from '../../lib/cms'
import {attikiCaseStudy} from '../../lib/content/attiki-case-study'
import {localizePath, resolvePageLocale} from '../../lib/i18n'
import {buildArticleJsonLd} from '../../lib/json-ld'
import {SITE_URL} from '../../lib/sanity-config'

export const prerender = false

const locale = resolvePageLocale(Astro.currentLocale)
const {siteSettings} = await getHomePageData(locale)
const pageUrl = `${SITE_URL}${localizePath(attikiCaseStudy.path, locale)}`
const jsonLd = buildArticleJsonLd({
  headline: attikiCaseStudy.title,
  description: attikiCaseStudy.metaDescription,
  url: pageUrl,
})
---

<Layout
  documentTitle={attikiCaseStudy.metaTitle}
  description={attikiCaseStudy.metaDescription}
  jsonLd={jsonLd}
  siteSettings={siteSettings}
  locale={locale}
>
  <SiteNav siteSettings={siteSettings} locale={locale} />
  <main>
    <AttikiCaseStudyView locale={locale} />
  </main>
  <SiteFooter locale={locale} siteSettings={siteSettings} />
</Layout>
