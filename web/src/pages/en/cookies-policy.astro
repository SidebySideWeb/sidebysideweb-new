---
import LegalLayout from '../../layouts/LegalLayout.astro'
import {getHomePageData} from '../../lib/cms'
import {resolvePageLocale} from '../../lib/i18n'

export const prerender = false

const locale = resolvePageLocale(Astro.currentLocale)
const {siteSettings} = await getHomePageData(locale)
---

<LegalLayout
  title="Cookie Policy"
  description="Cookie policy for sidebysideweb.gr"
  lastUpdated="July 13, 2026"
  siteSettings={siteSettings}
  locale={locale}
>
  <p>
    This policy explains how sidebysideweb.gr uses cookies and similar technologies.
  </p>

  <h2>1. What Are Cookies?</h2>
  <p>
    Cookies are small text files stored on your device when you visit a website. They help the site
    function properly and improve your experience.
  </p>

  <h2>2. Types of Cookies We Use</h2>

  <h3>Essential Cookies</h3>
  <p>Required for basic website functionality. They cannot be disabled.</p>

  <h3>Performance Cookies</h3>
  <p>
    Help us understand how visitors use the site (e.g. Google Analytics, if enabled).
  </p>

  <h3>Functional Cookies</h3>
  <p>Store your preferences, such as language or display settings.</p>

  <h2>3. Managing Cookies</h2>
  <p>
    You can manage or delete cookies through your browser settings. Disabling certain cookies may
    affect website functionality.
  </p>

  <h2>4. Contact</h2>
  <p>
    For questions about cookies, contact us at{' '}
    <a class="text-secondary hover:underline" href={`mailto:${siteSettings.contactEmail}`}>
      {siteSettings.contactEmail}
    </a>.
  </p>
</LegalLayout>
