---
import Layout from '../../layouts/Layout.astro'
import SiteNav from '../../components/SiteNav.astro'
import SiteFooter from '../../components/SiteFooter.astro'
import AttikiCaseStudyView from '../../components/case-studies/AttikiCaseStudyView.astro'
import MetaixmioCaseStudyView from '../../components/case-studies/MetaixmioCaseStudyView.astro'
import {getCaseStudyPageData} from '../../lib/cms'
import {CASE_STUDY_SLUG_REDIRECTS} from '../../lib/case-study-paths'
import {localizePath, resolvePageLocale} from '../../lib/i18n'
import {buildArticleJsonLd} from '../../lib/json-ld'
import {SITE_URL} from '../../lib/sanity-config'
import {getUiStrings} from '../../lib/ui-strings'

export const prerender = false

const locale = resolvePageLocale(Astro.currentLocale)
const ui = getUiStrings(locale)
const {slug} = Astro.params
if (!slug) {
  return Astro.redirect(localizePath('/', locale))
}

const redirected = CASE_STUDY_SLUG_REDIRECTS[slug]
if (redirected) {
  return Astro.redirect(localizePath(redirected, locale), 301)
}

const {caseStudy, siteSettings} = await getCaseStudyPageData(slug, locale)
const layout = caseStudy?.layout
const hasValidLayout = layout === 'automation' || layout === 'strategy'

if (!caseStudy || !hasValidLayout) {
  Astro.response.status = 404
}

const metaTitle = caseStudy?.seo?.metaTitle ?? caseStudy?.title
const metaDescription = caseStudy?.seo?.metaDescription ?? caseStudy?.summary
const pageUrl = `${SITE_URL}${localizePath(`/case-studies/${slug}`, locale)}`
const jsonLd =
  caseStudy && hasValidLayout
    ? buildArticleJsonLd({
        headline: caseStudy.title ?? metaTitle ?? '',
        description: metaDescription ?? '',
        url: pageUrl,
      })
    : undefined
---

{
  caseStudy && hasValidLayout ? (
    <Layout
      title={metaTitle}
      description={metaDescription}
      jsonLd={jsonLd}
      siteSettings={siteSettings}
      locale={locale}
    >
      <SiteNav siteSettings={siteSettings} locale={locale} />
      <main>
        {layout === 'automation' ? (
          <AttikiCaseStudyView caseStudy={caseStudy} locale={locale} />
        ) : (
          <MetaixmioCaseStudyView caseStudy={caseStudy} locale={locale} />
        )}
      </main>
      <SiteFooter locale={locale} siteSettings={siteSettings} />
    </Layout>
  ) : (
    <Layout title={ui.notFoundTitle} siteSettings={siteSettings} locale={locale}>
      <SiteNav siteSettings={siteSettings} locale={locale} />
      <main class="mx-auto max-w-3xl px-margin-container py-40 text-center">
        <h1 class="mb-4 text-headline-lg text-primary">{ui.notFoundTitle}</h1>
        <p class="mb-8 text-on-surface-variant">{ui.notFoundBody}</p>
        <a class="btn-primary-orange rounded-lg px-8 py-3" href={`${localizePath('/', locale)}#cases`}>
          {ui.notFoundCta}
        </a>
      </main>
      <SiteFooter locale={locale} siteSettings={siteSettings} />
    </Layout>
  )
}
